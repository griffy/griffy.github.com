<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Strict//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-strict.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="en" lang="en">
  <head>
    <link href='http://fonts.googleapis.com/css?family=Quicksand|Chivo|Ubuntu+Condensed|Alice|Tinos|Kelly+Slab|Droid+Sans|Open+Sans|Droid+Serif|Ubuntu|Arvo|Philosopher' rel='stylesheet' type='text/css'>
    <link rel="stylesheet" type="text/css" href="main.css">
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>
    <title>Joel Griffith - {{ page.title }}</title>
  </head>
  <body>
    <div id="container">
      <div id="header">
        <h1>Joel Griffith</h1>
      </div>
      <div id="nav">
        <ul>
          {% if page.title == 'About Me' %}
          <li><a class="active" href="index.html">Home</a></li>
          {% else %}
          <li><a href="index.html">Home</a></li>
          {% endif %}
          
          {% if page.title == 'Projects' %}
          <li><a class="active" href="projects.html">Projects</a></li>
          {% else %}
          <li><a href="projects.html">Projects</a></li>
          {% endif %}
          
          {% if page.title == 'Resume' %}
          <li><a class="active" href="resume.html">R&#233;sum&#233;</a></li>
          {% else %}
          <li><a href="resume.html">R&#233;sum&#233;</a></li>
          {% endif %}
          
          {% if page.title == 'Contact Me' %}
          <li><a class="active" href="contact.html">Contact Me</a></li>
          {% else %}
          <li><a href="contact.html">Contact Me</a></li>
          {% endif %}
          
          {% if page.title == 'Blog' or post.title %}
          <li><a class="active" href="blog.html">Blog</a></li>
          {% else %}
          <li><a href="blog.html">Blog</a></li>
          {% endif %}
        </ul>
      </div>
      <br />
      <div id="content">
        <div id="infobox" class="shadow">
          {{ content }}
        </div>
      </div>
    </div>
    <div id="footer">
      <span>Copyright 2011 Joel Griffith. All rights reserved.</span>
    </div>
  </body>
</html>
