html {
    height: 100%;
    padding: 0;
    margin: 0;
    background: url(images/2-darker.jpg) no-repeat center center fixed;
    -webkit-background-size: cover;
    -moz-background-size: cover;
    -o-background-size: cover;
    background-size: cover;
    font-family: 'Open Sans', 'Droid Serif', sans-serif;
}

body {
    height: 100%;
}

#container {
    height: auto;
    min-height: 100%;
}

#header h1 {
    font-family: 'Droid Sans', 'Ubuntu', sans-serif;
    text-shadow: 0 0 0.2em #d79421;
    color: #fcfcfc;
    text-align: center;
}

#nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    text-align: center;
}

#nav ul li {
    display: inline;
    margin: 0;
    padding: 0;
}

#nav ul li a {
    margin: 0 0 0 1px;
    padding: 3px 10px;
    font-family: 'Ubuntu', sans-serif;
    color: #fbfbfb;
    text-transform: none;
    /*font-weight: 100;*/
    margin-bottom: 0;
}

#nav ul li a:hover {
    color: #d79421;
}

#nav ul li a.active {
    text-decoration: none;
}

#content {
    color: #ffffff;
}

#infobox {
    color: #000000;
    margin: auto;
    background: #ffffff;

    border: 2px solid #2d2d2d;
    -moz-border-radius: 5px;
    -webkit-border-radius: 5px;

    padding: 30px 30px 30px 30px;
    min-width: 40%;
    max-width: 60%;
}

#infobox a {
    color: #2d2d2d;
}

#infobox a:hover {
    color: #d79421;
}

#post {
    color: #000000;
    margin: auto;
    background: #ffffff;

    border: 2px solid #2d2d2d;
    -moz-border-radius: 5px;
    -webkit-border-radius: 5px;

    padding: 30px 30px 30px 30px;
    min-width: 40%;
    max-width: 60%;
}

#post a {
    color: #2d2d2d;
}

#post a:hover {
    color: #d79421;
}

.post_preview {
    color: #000000;
    margin: auto;
    background: #ffffff;

    border: 2px solid #2d2d2d;
    -moz-border-radius: 5px;
    -webkit-border-radius: 5px;

    padding: 30px 30px 30px 30px;
    min-width: 40%;
    max-width: 60%;
}

.post_preview a {
    color: #2d2d2d;
}

.post_preview a:hover {
    color: #d79421;
}

#disqus_thread {
    margin: auto;
}

#footer {
    font-size: 9pt;
    text-align: center;
    clear: both;
    position: relative;
    z-index: 10;
    height: 10px;
    margin-top: -10px;
    width: 100%;
}

#footer #rule {
    margin: auto;
    background: url(images/fader.png) no-repeat;
    width: 323px;
}

.shadow {
    -moz-box-shadow: inset 1px 1px 10px #2d2d2d;
    -webkit-box-shadow: inset 1px 1px 10px #2d2d2d;
    box-shadow: inset 1px 1px 10px #2d2d2d;
}
